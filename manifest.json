{
  "manifest_version": 3,
  "name": "PolicyLens",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://api.openai.com/*"],
  "background": { "service_worker": "src/background/service_worker.ts", "type": "module" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.tsx"],
      "css": ["src/sidebar/sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_title": "PolicyLens" }
}
